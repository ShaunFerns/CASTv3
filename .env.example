# CAST v3 local environment example
#
# Copy this file to .env for local development.
# Do not commit real .env files or secrets.

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Frontend build/runtime
BASE_PATH=/

# PostgreSQL
# Local example:
# DATABASE_URL=postgresql://cast:cast@localhost:5432/cast
DATABASE_URL=postgresql://user:password@localhost:5432/cast

# OpenAI
# The current prototype uses Replit-style names. Keep these names until the
# integration layer is renamed in a later production-hardening phase.
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Session and temporary production bootstrap access
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# CAST v3 bootstrap admin.
# This is the temporary production access model until Supabase Auth/OIDC is implemented.
CAST_BOOTSTRAP_ADMIN_EMAIL=admin@example.edu
CAST_BOOTSTRAP_ADMIN_NAME=CAST Bootstrap Admin
CAST_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password-16chars-min
CAST_BOOTSTRAP_INSTITUTION_NAME=CAST Preview Institution
CAST_BOOTSTRAP_INSTITUTION_SLUG=cast-preview

# Legacy admin login for legacy prototype routes only.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Obsolete development/preview bridge. Do not use as the CAST v3 access model.
# Never enable this in production.
CAST_V3_PREVIEW_BRIDGE=false
CAST_V3_PREVIEW_INSTITUTION_SLUG=cast-preview
CAST_V3_PREVIEW_INSTITUTION_NAME=CAST Preview Institution
CAST_V3_PREVIEW_USER_EMAIL=preview-admin@cast.local
CAST_V3_PREVIEW_USER_NAME=CAST Preview Admin
