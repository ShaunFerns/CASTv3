# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Local environment secrets - never commit these files.
# Keep example files committed so new environments can be configured safely.
.env*
!.env.example
!**/.env.example

# Uploaded files and user data
uploads/
tmp/
temp/

# Generated local reports and exports
exports/
*.xlsx
*.csv

# Database dumps and exports
*.sql
!lib/db/migrations/**/*.sql
!lib/db/validation/**/*.sql
*.dump
*.sqlite
*.sqlite3
*.db

# Log files
*.log
logs/
pnpm-debug.log*

# Sensitive key/cert material
*.pem
*.key
*.p12
*.pfx
